# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Railway backend base URL (onboarding API)
VITE_RAILWAY_URL=https://your-app.up.railway.app

# Stripe publishable key (safe to expose; only needed if you use Stripe.js client-side.
# The current flow redirects to a backend-created Checkout Session URL, so this is optional.)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
